# Google AI API Key
# Get your API key from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_AI_API_KEY=your-google-ai-api-key-here
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Appwrite Client Configuration
# These VITE_* values are safe to expose to the browser.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-appwrite-project-id
VITE_APPWRITE_DATABASE_ID=thinkdesk
VITE_APPWRITE_WORKSPACES_TABLE_ID=workspaces

# Appwrite MCP/API Provisioning Configuration
# Keep APPWRITE_API_KEY server-side only. Never commit a real key.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_DATABASE_ID=thinkdesk
APPWRITE_WORKSPACES_TABLE_ID=workspaces
FRONTEND_URL=https://your-thinkdesk-site.appwrite.network
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Legacy local backend configuration
# Only needed if you intentionally run the older local email backend.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Frontend Configuration
VITE_APP_URL=http://localhost:5173

# Environment
NODE_ENV=development
